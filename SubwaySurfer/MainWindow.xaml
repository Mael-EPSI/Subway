<Window x:Class="SubwaySurfer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Subway Surfer" Height="720" Width="1000"
        Background="Black"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        ResizeMode="NoResize">
  <Grid>
    <!-- Jeu -->
    <Canvas x:Name="GameCanvas" Width="1000" Height="720" Background="Black" />

    <!-- Overlay Menu -->
<StackPanel x:Name="MenuOverlay"
            VerticalAlignment="Center" HorizontalAlignment="Center"
            Panel.ZIndex="10">

  <!-- Sprite écran titre -->
  <Image x:Name="StartScreenImg" Width="120" Height="180"
         HorizontalAlignment="Center" Margin="0,0,0,16"/>

  <TextBlock Text="SUBWAY SURFER" FontSize="48" FontWeight="Bold"
             Foreground="#FFD700" HorizontalAlignment="Center"/>
  <TextBlock Text="Endless Runner" FontSize="18"
             Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,8,0,0"/>
  <TextBlock Text="Appuie sur ESPACE pour démarrer" FontSize="20"
             Foreground="White" HorizontalAlignment="Center" Margin="0,24,0,0"/>
  <TextBlock Text="← → A D  —  Changer de voie" FontSize="14"
             Foreground="#888888" HorizontalAlignment="Center" Margin="0,16,0,0"/>
  <TextBlock Text="↑ W ESPACE  —  Sauter" FontSize="14"
             Foreground="#888888" HorizontalAlignment="Center" Margin="0,4,0,0"/>
</StackPanel>
    <!-- Overlay Game Over -->
    <StackPanel x:Name="GameOverOverlay" Visibility="Collapsed"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Panel.ZIndex="10">
      <TextBlock Text="GAME OVER" FontSize="48" FontWeight="Bold"
                 Foreground="#E63946" HorizontalAlignment="Center"/>
      <TextBlock x:Name="FinalScoreText" FontSize="28" FontWeight="Bold"
                 Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,0"/>
      <TextBlock x:Name="BestScoreText" FontSize="20"
                 Foreground="#FFD700" HorizontalAlignment="Center" Margin="0,8,0,0"/>
      <TextBlock Text="Appuie sur ESPACE pour recommencer" FontSize="20"
                 Foreground="White" HorizontalAlignment="Center" Margin="0,24,0,0"/>
    </StackPanel>
  </Grid>
</Window>